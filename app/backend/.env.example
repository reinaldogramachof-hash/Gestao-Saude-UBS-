# ─────────────────────────────────────────────────────────────────────────────
# ARQUIVO: .env.example
# FUNÇÃO: Template seguro das variáveis de ambiente exigidas pelo backend.
#         Use este arquivo como referência ao criar o `.env` local ou ao
#         configurar segredos na infraestrutura sem expor valores reais no Git.
# ─────────────────────────────────────────────────────────────────────────────

# Banco de dados
DATABASE_URL=postgresql://user:password@host:5432/dbname

# JWT
JWT_SECRET=sua_chave_secreta_aqui

# Ambiente
NODE_ENV=development

# Supabase (integrações auxiliares)
SUPABASE_URL=https://SEU_PROJECT_REF.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_XXXXXXXXXXXXXXXX
SUPABASE_SECRET_KEY=sb_secret_XXXXXXXXXXXXXXXX

# VAPID (Web Push)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:contato@ubsmais.com.br

# Sentry (produção)
SENTRY_DSN_BACKEND=

# Porta local do backend
PORT=3001

# Resend (serviço de e-mails para reset de senhas)
RESEND_API_KEY=
FRONTEND_URL=https://seu-dominio.vercel.app
