# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Template de variáveis de ambiente
# Copie este arquivo para .env e preencha com suas credenciais reais.
# NUNCA commite o arquivo .env com valores reais.
# ─────────────────────────────────────────────────────────────────────────────

PORT=3001

# ─── Supabase (PostgreSQL) ───────────────────────────────────────────────────
# Obtenha em: https://supabase.com/dashboard/project/SEU_PROJECT_REF/settings/api
SUPABASE_URL=https://SEU_PROJECT_REF.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_XXXXXXXXXXXXXXXX
SUPABASE_SECRET_KEY=sb_secret_XXXXXXXXXXXXXXXX

# Connection string do PostgreSQL (pooler do Supabase, porta 6543)
DATABASE_URL=postgresql://postgres.SEU_PROJECT_REF:SUA_SENHA@aws-0-sa-east-1.pooler.supabase.com:6543/postgres

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=troque_por_uma_string_longa_e_aleatoria