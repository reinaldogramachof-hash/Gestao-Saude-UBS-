# Dependências — nunca versionar a pasta node_modules
node_modules/
app/frontend/node_modules/
app/backend/node_modules/

# Variáveis de ambiente — nunca versionar arquivos .env com senhas reais
.env
app/frontend/.env
app/backend/.env

