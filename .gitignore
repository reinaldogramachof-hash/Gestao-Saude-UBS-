seed_output.txt
dev.sqlite3

# Scripts de scaffold (utilitários do agente, não fazem parte do produto)
buildMigrations.js
scaffold.js

# Assets brutos do Stitch (imagens brutas — telas organizadas estão em /screens)
stitch_gest_o_sa_de_ubs/

# Sistema operacional
.DS_Store
Thumbs.db
